# Non-secret policy. Copy to /etc/opensandbox-gateway/gateway.env and replace
# every REQUIRED value before starting the unit.
OPENSANDBOX_GATEWAY_API_KEY_FILE=/etc/opensandbox-gateway/secrets/lifecycle-api-key
OPENSANDBOX_GATEWAY_CAPABILITY_TOKEN_FILE=/etc/opensandbox-gateway/secrets/capability-token
OPENSANDBOX_GATEWAY_SIGNING_KEY_FILE=/etc/opensandbox-gateway/secrets/record-signing-key
OPENSANDBOX_GATEWAY_TLS_CERT_FILE=/etc/opensandbox-gateway/tls/fullchain.pem
OPENSANDBOX_GATEWAY_TLS_KEY_FILE=/etc/opensandbox-gateway/tls/privkey.pem
OPENSANDBOX_GATEWAY_EGRESS_POLICY_FILE=/etc/opensandbox-gateway/egress-policy.v1.json
OPENSANDBOX_GATEWAY_STATE_PATH=/var/lib/opensandbox-gateway/state.sqlite3
OPENSANDBOX_GATEWAY_LISTEN_PORT=8443
OPENSANDBOX_GATEWAY_PUBLIC_AUTHORITY=REQUIRED_DNS_NAME:8443
OPENSANDBOX_GATEWAY_EXECUTOR_IMAGE=REQUIRED_REGISTRY/REQUIRED_IMAGE@sha256:REQUIRED_DIGEST
OPENSANDBOX_GATEWAY_EXECUTOR_ENTRYPOINT_JSON=["/app/docker-entrypoint.sh","uvicorn"]
OPENSANDBOX_GATEWAY_PROOF_KEY_ID=REQUIRED_PROOF_KEY_ID
OPENSANDBOX_GATEWAY_PROFILE_ID=REQUIRED_PROFILE_ID
OPENSANDBOX_GATEWAY_RUNTIME_SUBJECT=REQUIRED_RUNSC_SUBJECT
OPENSANDBOX_GATEWAY_POLICY_SUBJECT=REQUIRED_GATEWAY_POLICY_SUBJECT
OPENSANDBOX_GATEWAY_CALLBACK_SUBJECT=REQUIRED_CALLBACK_BOUNDARY_SUBJECT
OPENSANDBOX_GATEWAY_DENY_AUDIT_SUBJECT=REQUIRED_DENY_AUDIT_SUBJECT
OPENSANDBOX_GATEWAY_DENY_COUNTER_SUBJECT=REQUIRED_DENY_COUNTER_SUBJECT
OPENSANDBOX_GATEWAY_CALLBACK_BASE=https://REQUIRED_CALLBACK_HOST/api/ai/runtime/callbacks
OPENSANDBOX_GATEWAY_OPENAI_BASE=https://REQUIRED_MODEL_HOST/openai/v1
OPENSANDBOX_GATEWAY_ANTHROPIC_BASE=https://REQUIRED_MODEL_HOST/anthropic/v1
OPENSANDBOX_GATEWAY_TIMEOUT_SECONDS=5
OPENSANDBOX_GATEWAY_DISPATCH_TIMEOUT_SECONDS=3600
