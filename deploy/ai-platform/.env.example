POSTGRES_DB=ai_platform
POSTGRES_USER=ai_platform
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=54329
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_MAX_WAITING=100
DATABASE_POOL_CLOSE_TIMEOUT_SECONDS=5

REDIS_PORT=63799

MINIO_ROOT_USER=ai_platform_minio
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9009
MINIO_CONSOLE_PORT=9010
S3_BUCKET=ai-platform-artifacts

AI_PLATFORM_API_PORT=8020
RUNTIME_211_BASE_URL=
QUEUE_TENANT_PROCESSING_LIMIT=0
QUEUE_USER_PROCESSING_LIMIT=0
QUEUE_LEASE_SCAN_LIMIT=50
QUEUE_INSIGHT_SCAN_LIMIT=500
MEMORY_RETENTION_WORKER_CLEANUP_ENABLED=true
MEMORY_RETENTION_WORKER_CLEANUP_INTERVAL_SECONDS=300
MEMORY_RETENTION_WORKER_CLEANUP_LIMIT=200
MULTI_AGENT_DISPATCH_WORKER_ENABLED=false
MULTI_AGENT_DISPATCH_WORKER_INTERVAL_SECONDS=30
MULTI_AGENT_DISPATCH_WORKER_LIMIT=1
MULTI_AGENT_DISPATCH_WORKER_USER_ID=system:multi-agent-dispatcher
TRUSTED_PRINCIPAL_SECRET=change_me_gateway_secret
EXISTING_AUTH_BASE_URL=http://10.56.0.25:7263
EXISTING_USER_INFO_BASE_URL=http://10.56.0.25:5166
EXISTING_AUTH_TIMEOUT_SECONDS=15
CORS_ALLOW_ORIGINS=http://localhost:9527,http://127.0.0.1:9527,http://10.56.0.211:8080,http://10.56.0.211:18001
AI_SESSION_SECRET=change_me_ai_session_secret
AI_SESSION_COOKIE_NAME=ai_platform_session
AI_SESSION_COOKIE_SECURE=false
AI_SESSION_MAX_AGE_SECONDS=28800
# POC only: allow browser-provided X-AI-User-* principal without gateway signing.
# Keep false for production; use an auth gateway to inject the signed principal.
FRONTEND_POC_AUTH_ENABLED=false

# Optional model gateway config for future platform-owned LLM executors.
# Keep real tokens only in server-side .env files.
LLM_GATEWAY_PROVIDER=openai_compatible
MODEL_GATEWAY_REQUEST_CONCURRENCY_LIMIT=0
OPENAI_BASE_URL=http://10.56.0.211:3002/v1
OPENAI_API_KEY=change_me_newapi_token
OPENAI_MODEL=deepseek-v4-flash
ANTHROPIC_BASE_URL=http://10.56.0.211:3002
ANTHROPIC_AUTH_TOKEN=change_me_newapi_token
ANTHROPIC_MODEL=deepseek-v4-flash
CLAUDE_AGENT_MODEL=deepseek-v4-flash
CLAUDE_AGENT_SDK_ENABLED=false
CLAUDE_AGENT_SDK_TIMEOUT_SECONDS=120
CLAUDE_AGENT_SDK_MAX_TURNS=128
CLAUDE_AGENT_SDK_EFFORT=xhigh
CLAUDE_AGENT_SDK_MAX_THINKING_TOKENS=16384
# Current intranet worker mode: allow Claude SDK Bash without per-tool frontend
# confirmation. The runner treats bypassPermissions as platform full access and
# maps the SDK permission mode safely for root containers. Set these back to
# dontAsk/Read,Glob,LS plus Write,Edit,NotebookEdit disallowed if the platform
# permission gate is required.
CLAUDE_AGENT_PERMISSION_MODE=bypassPermissions
CLAUDE_AGENT_ALLOWED_TOOLS=Read,Glob,LS,Bash
CLAUDE_AGENT_DISALLOWED_TOOLS=
CLAUDE_AGENT_WORKSPACE_ROOT=/tmp/ai-platform-agent-workspaces
CLAUDE_AGENT_SDK_SKILLS=general-chat,qa-file-reviewer,baoyu-translate

# Optional RAGFlow knowledge executor config. Keep real tokens only on the server.
RAGFLOW_API_URL=http://10.56.0.211
RAGFLOW_API_KEY=change_me_ragflow_token
RAGFLOW_DEFAULT_DATASET_ID=change_me_dataset_id
RAGFLOW_TIMEOUT_SECONDS=30
RAGFLOW_TOP_K=3
RAGFLOW_SIMILARITY_THRESHOLD=0.2

# Do not put authenticated package indexes in deploy env files. The committed
# compose does not forward package-index variables as Docker build args because
# build args can persist in image layers.
AI_PLATFORM_IMAGE=ai-platform:local
SANDBOX_CALLBACK_TOKEN=change_me_sandbox_callback_token
